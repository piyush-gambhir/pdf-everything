# Copy to .env.deploy.production or .env.deploy.development and fill in.
# Both files are gitignored — never commit real values.

# Docker Hub — generate token at https://hub.docker.com/settings/security
DOCKERHUB_USERNAME=piyushgambhir
DOCKERHUB_TOKEN=

# Optional overrides (defaults are sensible)
# IMAGE_NAME=piyushgambhir/markdown-to-pdf
# DOCKERFILE_PATH=deploy/docker/Dockerfile
# BUILD_PLATFORMS=linux/amd64,linux/arm64

# --- GCP Cloud Run (uncomment once a project is chosen) ---
# GCP_CONFIG=piyush-personal           # gcloud config configuration name
# GCP_PROJECT=                          # e.g. piyushgambhir-prod
# GCP_REGION=asia-south1

# --- AWS Lambda (container image) ---
# Copy this block into .env.deploy.lambda and fill in. Used by scripts/deploy-lambda.sh.
# AWS credentials come from the environment / ~/.aws (standard aws CLI resolution).
#
# AWS_REGION=ap-south-1
# ECR_REPOSITORY=markdown-to-pdf
# FUNCTION_NAME=markdown-to-pdf
# LAMBDA_EXECUTION_ROLE_ARN=arn:aws:iam::<account-id>:role/<lambda-exec-role>
#
# Optional overrides:
# ARCHITECTURE=arm64                   # arm64 | x86_64
# MEMORY_MB=2048                       # Chromium needs headroom (>=1536)
# TIMEOUT_S=60
# FUNCTION_URL_AUTH=AWS_IAM            # AWS_IAM | NONE  (NONE = publicly invokable)
# API_TOKEN=                           # if set, required as Bearer token on /v1/render
