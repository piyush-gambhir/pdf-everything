{
  "name": "@pdf-everything/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "fumadocs-mdx && next dev -p 3002",
    "build": "fumadocs-mdx && next build",
    "build:cloudflare": "fumadocs-mdx && next build && node ../scripts/prepare-cloudflare-assets.mjs pdf-everything",
    "deploy": "pnpm build:cloudflare && wrangler deploy",
    "start": "next start -p 3002",
    "lint": "eslint",
    "typecheck": "fumadocs-mdx && next typegen && tsc --noEmit",
    "clean": "rm -rf .next out .cloudflare .source"
  },
  "dependencies": {
    "@pdf-everything/types": "workspace:*",
    "clsx": "^2.1.1",
    "fumadocs-core": "16.11.4",
    "fumadocs-mdx": "15.1.1",
    "fumadocs-ui": "npm:@fumadocs/base-ui@16.11.4",
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.3",
    "wrangler": "^4"
  }
}
