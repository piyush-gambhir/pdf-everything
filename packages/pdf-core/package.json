{
  "name": "@pdf-everything/pdf-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./organize": {
      "types": "./dist/organize/index.d.ts",
      "import": "./dist/organize/index.js"
    },
    "./edit": {
      "types": "./dist/edit/index.d.ts",
      "import": "./dist/edit/index.js"
    },
    "./convert-to": {
      "types": "./dist/convert-to/index.d.ts",
      "import": "./dist/convert-to/index.js"
    },
    "./convert-from": {
      "types": "./dist/convert-from/index.d.ts",
      "import": "./dist/convert-from/index.js"
    },
    "./misc": {
      "types": "./dist/misc/index.d.ts",
      "import": "./dist/misc/index.js"
    },
    "./forms": {
      "types": "./dist/forms/index.d.ts",
      "import": "./dist/forms/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "sharp": "^0.34.5",
    "@pdf-everything/types": "workspace:*"
  },
  "devDependencies": {
    "@pdf-everything/tsconfig": "workspace:*",
    "@types/node": "^22.10.7",
    "@types/pdf-parse": "^1.1.4",
    "typescript": "^5.7.3",
    "vitest": "^3.2.6"
  }
}
