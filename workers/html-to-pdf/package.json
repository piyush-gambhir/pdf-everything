{
  "name": "html-to-pdf",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Standalone HTML → PDF microservice powered by headless Chromium.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/deploy/docker/index.js",
    "dev": "tsx watch deploy/docker/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"core/**/*.ts\" \"deploy/docker/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"core/**/*.ts\" \"deploy/docker/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "puppeteer-core": "^24.15.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
